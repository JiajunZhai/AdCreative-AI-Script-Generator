# ==========================================
# 云端高精模型配置 (DeepSeek)
# ==========================================
# 从 https://platform.deepseek.com/ 获取 API Key
DEEPSEEK_API_KEY="sk-your-deepseek-api-key"

# DeepSeek 官方 API 终点
DEEPSEEK_BASE_URL="https://api.deepseek.com"

# 模型选择: 
# deepseek-chat (V3): 速度快，逻辑强，适合日常生成
# deepseek-reasoner (R1): 强逻辑推理，适合深层心理学拆解
DEEPSEEK_MODEL="deepseek-chat"

# ==========================================
# 本地模型配置 (Ollama)
# ==========================================
OLLAMA_BASE_URL="http://192.168.0.48:11434/v1"
OLLAMA_MODEL_EXTRACT="gemma4:e4b"
OLLAMA_MODEL_DIRECTOR="qwen3.5:9b"

# ==========================================
# 全局运行模式
# ==========================================
# 默认模式: cloud (云端) / local (本地)
LLM_RUNTIME_MODE="cloud"
